{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "6857666292213755974"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources. Defaults to the resource group location."
      }
    },
    "namePrefix": {
      "type": "string",
      "defaultValue": "is-ai-native",
      "minLength": 3,
      "maxLength": 20,
      "metadata": {
        "description": "Name prefix applied to every resource. Must contain only lowercase letters, numbers, and hyphens; 3–20 chars."
      }
    },
    "containerImage": {
      "type": "string",
      "metadata": {
        "description": "Container image to deploy, e.g. ghcr.io/org/repo:sha-abc1234."
      }
    },
    "githubToken": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "GitHub PAT used by the scanner to raise API rate limits. Leave empty for unauthenticated access."
      }
    },
    "enableSharing": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Enable the report-sharing feature. When true, an Azure Files share is mounted for report persistence."
      }
    },
    "enableAppInsights": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Enable Azure Application Insights telemetry for scan/report monitoring."
      }
    },
    "enableAvailabilityMonitoring": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Enable low-cost external website availability monitoring. Requires Application Insights and a monitoring alert email address."
      }
    },
    "monitoringAlertEmail": {
      "type": "string",
      "defaultValue": "salnikov@gmail.com",
      "metadata": {
        "description": "Email address that receives website availability alerts. Leave empty to skip alert creation."
      }
    },
    "monitoringUrl": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional public URL to probe. Leave empty to monitor the default Container App URL."
      }
    },
    "containerStartupStrategy": {
      "type": "string",
      "defaultValue": "scale-to-zero",
      "allowedValues": [
        "scale-to-zero",
        "keep-warm"
      ],
      "metadata": {
        "description": "Container startup strategy. Use scale-to-zero for lowest cost, or keep-warm to keep one replica ready and reduce cold starts."
      }
    },
    "acrName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Azure Container Registry name. When provided, the Container App pulls from ACR using its managed identity."
      }
    },
    "customDomainName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Custom domain name to bind (e.g. scan.example.com). Leave empty to use the default Azure FQDN. Requires a one-time CLI setup: see README."
      }
    },
    "managedCertName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Name of the existing managed certificate in the Container Apps environment. Created during one-time CLI setup."
      }
    },
    "secondaryCustomDomainName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional secondary custom domain name to keep bound alongside the primary domain during migrations or cutovers."
      }
    },
    "secondaryManagedCertName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Name of the existing managed certificate for the optional secondary custom domain."
      }
    },
    "siteOrigin": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Public site origin used for canonical URLs, sitemap entries, and social card URLs. Leave empty to omit a canonical origin."
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {
        "application": "is-ai-native",
        "managedBy": "bicep"
      },
      "metadata": {
        "description": "Tags applied to every resource."
      }
    }
  },
  "variables": {
    "baseEnv": [
      {
        "name": "NODE_ENV",
        "value": "production"
      },
      {
        "name": "PORT",
        "value": "3000"
      },
      {
        "name": "ENABLE_SHARING",
        "value": "[if(parameters('enableSharing'), 'true', 'false')]"
      }
    ],
    "siteOriginEnv": "[if(not(equals(parameters('siteOrigin'), '')), createArray(createObject('name', 'SITE_ORIGIN', 'value', parameters('siteOrigin'))), createArray())]",
    "tokenEnv": "[if(not(equals(parameters('githubToken'), '')), createArray(createObject('name', 'GH_TOKEN_FOR_SCAN', 'secretRef', 'gh-token-for-scan')), createArray())]",
    "appInsightsEnv": "[if(parameters('enableAppInsights'), createArray(createObject('name', 'APPLICATIONINSIGHTS_CONNECTION_STRING', 'secretRef', 'app-insights-connection-string')), createArray())]",
    "appEnv": "[concat(variables('baseEnv'), variables('siteOriginEnv'), variables('tokenEnv'), variables('appInsightsEnv'))]",
    "appSecrets": "[if(not(equals(parameters('githubToken'), '')), createArray(createObject('name', 'gh-token-for-scan', 'value', parameters('githubToken'))), createArray())]",
    "appVolumes": "[if(parameters('enableSharing'), createArray(createObject('name', 'reports-data', 'storageType', 'AzureFile', 'storageName', 'reports-data')), createArray())]",
    "appVolumeMounts": "[if(parameters('enableSharing'), createArray(createObject('mountPath', '/app/data', 'volumeName', 'reports-data')), createArray())]",
    "availabilityMonitoringEnabled": "[and(and(parameters('enableAppInsights'), parameters('enableAvailabilityMonitoring')), not(equals(parameters('monitoringAlertEmail'), '')))]",
    "monitoringActionGroupShortName": "[take(replace(format('{0}mon', parameters('namePrefix')), '-', ''), 12)]",
    "monitoringLocationIds": [
      "us-il-ch1-azr"
    ],
    "customDomainBindings": "[concat(if(and(not(equals(parameters('customDomainName'), '')), not(equals(parameters('managedCertName'), ''))), createArray(createObject('name', parameters('customDomainName'), 'bindingType', 'SniEnabled', 'certificateId', resourceId('Microsoft.App/managedEnvironments/managedCertificates', format('{0}-env', parameters('namePrefix')), parameters('managedCertName')))), createArray()), if(and(not(equals(parameters('secondaryCustomDomainName'), '')), not(equals(parameters('secondaryManagedCertName'), ''))), createArray(createObject('name', parameters('secondaryCustomDomainName'), 'bindingType', 'SniEnabled', 'certificateId', resourceId('Microsoft.App/managedEnvironments/managedCertificates', format('{0}-env', parameters('namePrefix')), parameters('secondaryManagedCertName')))), createArray()))]"
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[format('{0}-logs', parameters('namePrefix'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 31,
        "features": {
          "enableLogAccessUsingOnlyResourcePermissions": true
        }
      }
    },
    {
      "condition": "[parameters('enableAppInsights')]",
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[format('{0}-appi', parameters('namePrefix'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web",
        "RetentionInDays": 30,
        "WorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', format('{0}-logs', parameters('namePrefix')))]",
        "publicNetworkAccessForIngestion": "Enabled",
        "publicNetworkAccessForQuery": "Enabled"
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', format('{0}-logs', parameters('namePrefix')))]"
      ]
    },
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2024-03-01",
      "name": "[format('{0}-env', parameters('namePrefix'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "appLogsConfiguration": {
          "destination": "log-analytics",
          "logAnalyticsConfiguration": {
            "customerId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', format('{0}-logs', parameters('namePrefix'))), '2023-09-01').customerId]",
            "sharedKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', format('{0}-logs', parameters('namePrefix'))), '2023-09-01').primarySharedKey]"
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', format('{0}-logs', parameters('namePrefix')))]"
      ]
    },
    {
      "condition": "[parameters('enableSharing')]",
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[take(toLower(replace(replace(replace(format('{0}data', parameters('namePrefix')), '-', ''), '_', ''), '.', '')), 24)]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "Standard_LRS"
      },
      "kind": "StorageV2",
      "properties": {
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false,
        "supportsHttpsTrafficOnly": true,
        "networkAcls": {
          "defaultAction": "Allow"
        }
      }
    },
    {
      "condition": "[parameters('enableSharing')]",
      "type": "Microsoft.Storage/storageAccounts/fileServices",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/{1}', take(toLower(replace(replace(replace(format('{0}data', parameters('namePrefix')), '-', ''), '_', ''), '.', '')), 24), 'default')]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', take(toLower(replace(replace(replace(format('{0}data', parameters('namePrefix')), '-', ''), '_', ''), '.', '')), 24))]"
      ]
    },
    {
      "condition": "[parameters('enableSharing')]",
      "type": "Microsoft.Storage/storageAccounts/fileServices/shares",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/{1}/{2}', take(toLower(replace(replace(replace(format('{0}data', parameters('namePrefix')), '-', ''), '_', ''), '.', '')), 24), 'default', 'data')]",
      "properties": {
        "shareQuota": 1
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/fileServices', take(toLower(replace(replace(replace(format('{0}data', parameters('namePrefix')), '-', ''), '_', ''), '.', '')), 24), 'default')]"
      ]
    },
    {
      "condition": "[parameters('enableSharing')]",
      "type": "Microsoft.App/managedEnvironments/storages",
      "apiVersion": "2024-03-01",
      "name": "[format('{0}/{1}', format('{0}-env', parameters('namePrefix')), 'reports-data')]",
      "properties": {
        "azureFile": {
          "accountName": "[take(toLower(replace(replace(replace(format('{0}data', parameters('namePrefix')), '-', ''), '_', ''), '.', '')), 24)]",
          "accountKey": "[listKeys(resourceId('Microsoft.Storage/storageAccounts', take(toLower(replace(replace(replace(format('{0}data', parameters('namePrefix')), '-', ''), '_', ''), '.', '')), 24)), '2023-05-01').keys[0].value]",
          "shareName": "data",
          "accessMode": "ReadWrite"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', format('{0}-env', parameters('namePrefix')))]",
        "[resourceId('Microsoft.Storage/storageAccounts', take(toLower(replace(replace(replace(format('{0}data', parameters('namePrefix')), '-', ''), '_', ''), '.', '')), 24))]"
      ]
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[format('{0}-app', parameters('namePrefix'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "environmentId": "[resourceId('Microsoft.App/managedEnvironments', format('{0}-env', parameters('namePrefix')))]",
        "configuration": {
          "ingress": {
            "external": true,
            "targetPort": 3000,
            "transport": "http",
            "allowInsecure": false,
            "customDomains": "[variables('customDomainBindings')]"
          },
          "secrets": "[concat(variables('appSecrets'), if(parameters('enableAppInsights'), createArray(createObject('name', 'app-insights-connection-string', 'value', reference(resourceId('Microsoft.Insights/components', format('{0}-appi', parameters('namePrefix'))), '2020-02-02').ConnectionString)), createArray()), if(not(equals(parameters('acrName'), '')), createArray(createObject('name', 'acr-password', 'value', listCredentials(resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName')), '2023-07-01').passwords[0].value)), createArray()))]",
          "registries": "[if(not(equals(parameters('acrName'), '')), createArray(createObject('server', format('{0}.azurecr.io', parameters('acrName')), 'username', listCredentials(resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName')), '2023-07-01').username, 'passwordSecretRef', 'acr-password')), createArray())]"
        },
        "template": {
          "containers": [
            {
              "name": "app",
              "image": "[parameters('containerImage')]",
              "resources": {
                "cpu": "[json('0.25')]",
                "memory": "0.5Gi"
              },
              "env": "[variables('appEnv')]",
              "volumeMounts": "[variables('appVolumeMounts')]",
              "probes": [
                {
                  "type": "Liveness",
                  "httpGet": {
                    "path": "/api/health",
                    "port": 3000
                  },
                  "initialDelaySeconds": 10,
                  "periodSeconds": 30,
                  "timeoutSeconds": 5,
                  "failureThreshold": 3
                },
                {
                  "type": "Readiness",
                  "httpGet": {
                    "path": "/api/health",
                    "port": 3000
                  },
                  "initialDelaySeconds": 5,
                  "periodSeconds": 10,
                  "timeoutSeconds": 5,
                  "successThreshold": 1,
                  "failureThreshold": 3
                }
              ]
            }
          ],
          "volumes": "[variables('appVolumes')]",
          "scale": {
            "minReplicas": "[if(equals(parameters('containerStartupStrategy'), 'keep-warm'), 1, 0)]",
            "maxReplicas": 4,
            "rules": [
              {
                "name": "http-scaling",
                "http": {
                  "metadata": {
                    "concurrentRequests": "20"
                  }
                }
              }
            ]
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/components', format('{0}-appi', parameters('namePrefix')))]",
        "[resourceId('Microsoft.App/managedEnvironments/storages', format('{0}-env', parameters('namePrefix')), 'reports-data')]",
        "[resourceId('Microsoft.App/managedEnvironments', format('{0}-env', parameters('namePrefix')))]"
      ]
    },
    {
      "condition": "[variables('availabilityMonitoringEnabled')]",
      "type": "Microsoft.Insights/actionGroups",
      "apiVersion": "2023-01-01",
      "name": "[format('{0}-site-alerts', parameters('namePrefix'))]",
      "location": "global",
      "tags": "[parameters('tags')]",
      "properties": {
        "enabled": true,
        "groupShortName": "[variables('monitoringActionGroupShortName')]",
        "emailReceivers": [
          {
            "name": "primary-email",
            "emailAddress": "[parameters('monitoringAlertEmail')]",
            "useCommonAlertSchema": true
          }
        ]
      }
    },
    {
      "condition": "[variables('availabilityMonitoringEnabled')]",
      "type": "Microsoft.Insights/webtests",
      "apiVersion": "2022-06-15",
      "name": "[format('{0}-site-availability', parameters('namePrefix'))]",
      "location": "[parameters('location')]",
      "kind": "standard",
      "tags": "[union(parameters('tags'), createObject(format('hidden-link:{0}', resourceId('Microsoft.Insights/components', format('{0}-appi', parameters('namePrefix')))), 'Resource'))]",
      "properties": {
        "copy": [
          {
            "name": "Locations",
            "count": "[length(variables('monitoringLocationIds'))]",
            "input": {
              "Id": "[variables('monitoringLocationIds')[copyIndex('Locations')]]"
            }
          }
        ],
        "Name": "[format('{0}-site-availability', parameters('namePrefix'))]",
        "SyntheticMonitorId": "[format('{0}-site-availability', parameters('namePrefix'))]",
        "Description": "Lowest-cost public site availability check for email alerting.",
        "Enabled": true,
        "Frequency": 900,
        "Timeout": 30,
        "Kind": "standard",
        "RetryEnabled": true,
        "Request": {
          "RequestUrl": "[if(not(equals(parameters('monitoringUrl'), '')), parameters('monitoringUrl'), format('https://{0}', reference(resourceId('Microsoft.App/containerApps', format('{0}-app', parameters('namePrefix'))), '2024-03-01').configuration.ingress.fqdn))]",
          "HttpVerb": "GET",
          "ParseDependentRequests": true,
          "FollowRedirects": true
        },
        "ValidationRules": {
          "ExpectedHttpStatusCode": 200,
          "SSLCheck": true,
          "SSLCertRemainingLifetimeCheck": 14
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/components', format('{0}-appi', parameters('namePrefix')))]",
        "[resourceId('Microsoft.App/containerApps', format('{0}-app', parameters('namePrefix')))]"
      ]
    },
    {
      "condition": "[variables('availabilityMonitoringEnabled')]",
      "type": "Microsoft.Insights/metricAlerts",
      "apiVersion": "2018-03-01",
      "name": "[format('{0}-site-down', parameters('namePrefix'))]",
      "location": "global",
      "tags": "[parameters('tags')]",
      "properties": {
        "description": "Sends email when the public site is unavailable or returns non-200 responses from the lowest-cost availability test profile.",
        "enabled": true,
        "severity": 1,
        "scopes": [
          "[resourceId('Microsoft.Insights/components', format('{0}-appi', parameters('namePrefix')))]",
          "[resourceId('Microsoft.Insights/webtests', format('{0}-site-availability', parameters('namePrefix')))]"
        ],
        "evaluationFrequency": "PT15M",
        "windowSize": "PT15M",
        "autoMitigate": true,
        "criteria": {
          "odata.type": "Microsoft.Azure.Monitor.WebtestLocationAvailabilityCriteria",
          "componentId": "[resourceId('Microsoft.Insights/components', format('{0}-appi', parameters('namePrefix')))]",
          "webTestId": "[resourceId('Microsoft.Insights/webtests', format('{0}-site-availability', parameters('namePrefix')))]",
          "failedLocationCount": 1
        },
        "actions": [
          {
            "actionGroupId": "[resourceId('Microsoft.Insights/actionGroups', format('{0}-site-alerts', parameters('namePrefix')))]"
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/components', format('{0}-appi', parameters('namePrefix')))]",
        "[resourceId('Microsoft.Insights/actionGroups', format('{0}-site-alerts', parameters('namePrefix')))]",
        "[resourceId('Microsoft.Insights/webtests', format('{0}-site-availability', parameters('namePrefix')))]"
      ]
    }
  ],
  "outputs": {
    "appUrl": {
      "type": "string",
      "metadata": {
        "description": "Public URL of the deployed application."
      },
      "value": "[format('https://{0}', reference(resourceId('Microsoft.App/containerApps', format('{0}-app', parameters('namePrefix'))), '2024-03-01').configuration.ingress.fqdn)]"
    },
    "containerAppName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Container App (used by CD workflow to update the image)."
      },
      "value": "[format('{0}-app', parameters('namePrefix'))]"
    },
    "appInsightsName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Application Insights component used for telemetry."
      },
      "value": "[if(parameters('enableAppInsights'), format('{0}-appi', parameters('namePrefix')), '')]"
    },
    "availabilityMonitoringConfigured": {
      "type": "bool",
      "metadata": {
        "description": "True when external website availability monitoring resources were deployed."
      },
      "value": "[variables('availabilityMonitoringEnabled')]"
    },
    "availabilityMonitoringTargetUrl": {
      "type": "string",
      "metadata": {
        "description": "URL monitored by the external availability test."
      },
      "value": "[if(variables('availabilityMonitoringEnabled'), if(not(equals(parameters('monitoringUrl'), '')), parameters('monitoringUrl'), format('https://{0}', reference(resourceId('Microsoft.App/containerApps', format('{0}-app', parameters('namePrefix'))), '2024-03-01').configuration.ingress.fqdn)), '')]"
    },
    "resourceGroupName": {
      "type": "string",
      "metadata": {
        "description": "Resource group name."
      },
      "value": "[resourceGroup().name]"
    }
  }
}