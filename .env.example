# Server
NODE_ENV=development
PORT=3000

# CORS — set to your frontend origin, or leave empty to disable
ALLOWED_ORIGIN=

# Frontend serving (set to true when running the single-container build)
SERVE_FRONTEND=false
FRONTEND_PATH=./frontend

# Report sharing (requires SQLite persistence)
ENABLE_SHARING=false
DB_PATH=./data/reports.db

# GitHub token — raises API rate limits for repo scanning
# Create at https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=
