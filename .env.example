# Server
NODE_ENV=development
PORT=3000

# CORS — set to your frontend origin, or leave empty to disable
ALLOWED_ORIGIN=

# Report sharing
ENABLE_SHARING=false
REPORTS_DIR=./data/reports

# Frontend path override. Leave unset for backend-only local development.
# npm run dev:full sets this automatically, and the single-container image auto-detects its bundled frontend.
# FRONTEND_PATH=./webapp/frontend

# Optional Azure Application Insights connection string for telemetry
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Default monitoring email for manual Azure deployment commands
MONITORING_ALERT_EMAIL=

# GitHub token — raises API rate limits for repo scanning
# Create at https://github.com/settings/tokens (no scopes needed for public repos)
GH_TOKEN_FOR_SCAN=

# GitHub CLI extension sync
# Target repository for the generated gh extension repo sync
GH_EXTENSION_REPOSITORY=webmaxru/gh-is-ai-native
# Fine-grained GitHub token with contents:write access to GH_EXTENSION_REPOSITORY
GH_EXTENSION_SYNC_TOKEN=

# VS Code Marketplace publishing
# Azure DevOps PAT with All accessible organizations and Marketplace (Manage) scope
VSCE_PAT=
