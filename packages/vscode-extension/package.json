{
  "name": "is-ai-native",
  "version": "0.1.4",
  "publisher": "salnikov",
  "displayName": "Is AI-Native",
  "description": "Scan workspaces and GitHub repositories for AI-native development primitives.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/extension.js",
  "icon": "media/icon.png",
  "homepage": "https://github.com/webmaxru/is-ai-native#readme",
  "bugs": {
    "url": "https://github.com/webmaxru/is-ai-native/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/webmaxru/is-ai-native.git"
  },
  "galleryBanner": {
    "color": "#0b2336",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "ai",
    "ai-native",
    "github-copilot",
    "repository-scanner",
    "developer-tools",
    "productivity"
  ],
  "contributes": {
    "commands": [
      {
        "command": "is-ai-native.scanWorkspace",
        "title": "Is AI-Native: Scan Workspace"
      },
      {
        "command": "is-ai-native.scanGitHub",
        "title": "Is AI-Native: Scan GitHub Repository"
      },
      {
        "command": "is-ai-native.openResults",
        "title": "Is AI-Native: Open Last Results"
      }
    ],
    "configuration": {
      "title": "Is AI-Native",
      "properties": {
        "isAiNative.githubToken": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional GitHub token used when scanning remote repositories from the extension."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.config.mjs",
    "test": "node --test tests/*.test.js"
  },
  "devDependencies": {
    "@is-ai-native/core": "file:../core",
    "esbuild": "^0.25.0"
  }
}
