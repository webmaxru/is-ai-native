{
  "name": "is-ai-native",
  "version": "0.1.4",
  "description": "CLI scanner for AI-native repository assessment",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "is-ai-native": "dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "build:standalone": "node ./scripts/build-standalone.mjs",
    "prepack": "npm run build",
    "test": "node --test tests/cli.test.js tests/formatters.test.js"
  },
  "keywords": [
    "ai",
    "cli",
    "copilot",
    "github",
    "scanner"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webmaxru/is-ai-native.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/webmaxru/is-ai-native/tree/main/packages/cli",
  "bugs": {
    "url": "https://github.com/webmaxru/is-ai-native/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "esbuild": "^0.25.12"
  }
}
