{
  "name": "is-ai-native-backend",
  "version": "1.0.0",
  "description": "Backend API for is-ai-native scanner",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node --env-file-if-exists=../../.env src/server.js",
    "dev": "node --env-file-if-exists=../../.env --watch src/server.js",
    "dev:full": "node --env-file-if-exists=../../.env --watch scripts/dev-full.js",
    "test": "node scripts/run-jest.js --runInBand",
    "test:unit": "node scripts/run-jest.js tests/unit --runInBand",
    "test:contract": "node scripts/run-jest.js tests/contract --runInBand",
    "test:integration": "node scripts/run-jest.js tests/integration --runInBand"
  },
  "dependencies": {
    "@is-ai-native/core": "file:../../packages/core",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^8.1.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "transform": {}
  }
}
