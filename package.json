{
  "name": "is-ai-native-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "backend",
    "packages/*"
  ],
  "scripts": {
    "build:gh-extension": "npm --workspace packages/cli run build:gh-extension",
    "test:frontend": "node --test frontend/tests/unit/*.test.js",
    "test:backend": "npm --workspace backend test",
    "test:cli": "node --test packages/cli/tests/*.test.js",
    "test:core": "node --test packages/core/tests/*.test.js",
    "build:vscode-extension": "npm --workspace packages/vscode-extension run build",
    "test:vscode-extension": "node --test packages/vscode-extension/tests/*.test.js",
    "package:vscode-extension": "cd packages/vscode-extension && npx @vscode/vsce package --no-dependencies -o is-ai-native.vsix",
    "publish:vscode-extension": "cd packages/vscode-extension && npx @vscode/vsce publish --no-dependencies"
  }
}