{
  "name": "ai-readiness-checker-frontend",
  "version": "1.0.0",
  "description": "Frontend UI for AI-Native Development Readiness Checker",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.{js,css,html}\" \"tests/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.{js,css,html}\" \"tests/**/*.js\""
  },
  "keywords": ["ai-native", "readiness", "checker", "frontend"],
  "license": "MIT",
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.12.0",
    "globals": "^15.11.0",
    "prettier": "^3.3.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
